*.py[cod]
*$py.class
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Distribution / packaging
build/
dist/
*.egg-info/

# Virtual environments
.venv/
.env/

# Jupyter Notebook checkpoints
.ipynb_checkpoints

# IDEs and editors
.vscode/
.idea/
*.swp

# Data and cache files
/data/cache/*
!/data/cache/.gitkeep
/data/exports/*
!/data/exports/.gitkeep
/data/info/*
!/data/info/.gitkeep
/data/logs/*
!/data/logs/.gitkeep
/data/portfolio/*
!/data/portfolio/.gitkeep
/data/price_hist/*
!/data/price_hist/.gitkeep
.cache/

# macOS
.DS_Store
.coverage

